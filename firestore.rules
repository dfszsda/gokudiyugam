rules_version = '2';

// Firebase Storage Rules for Gokudiyugam App
service firebase.storage {
  match /b/{bucket}/o {
    
    // 'uploads' ફોલ્ડર માટેના રૂલ્સ
    match /uploads/{category}/{fileName} {
      
      // કોઈપણ વ્યક્તિ ફોટા/વીડિયો જોઈ શકશે (Read access)
      allow read: if true;
      
      // માત્ર લોગીન થયેલ યુઝર જ ફાઈલ અપલોડ કરી શકશે (Write access)
      allow write: if request.auth != null 
                   && request.resource.size < 10 * 1024 * 1024 // 10MB limit
                   && request.resource.contentType.matches('image/.*|video/.*|audio/.*|application/pdf');
    }

    // અન્ય ફાઈલો માટે ડિફોલ્ટ સુરક્ષા
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}